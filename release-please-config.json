{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "include-component-in-tag": true,
  "tag-separator": "/",
  "separate-pull-requests": true,
  "component-no-space": true,
  "pull-request-title-pattern": "chore(${component}): release ${version}",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "revert", "section": "Reverts" },
    { "type": "chore", "section": "Miscellaneous Chores" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build System", "hidden": true },
    { "type": "ci", "section": "Continuous Integration", "hidden": true }
  ],
  "packages": {
    "backward-compatibility": { "component": "backward-compatibility" },
    "bazel": { "component": "bazel" },
    "bidirectional-streaming": { "component": "bidirectional-streaming" },
    "circular-dependency": { "component": "circular-dependency" },
    "client-side-lb": { "component": "client-side-lb" },
    "client-streaming": { "component": "client-streaming" },
    "duplicate": { "component": "duplicate" },
    "enum-compatibility": { "component": "enum-compatibility" },
    "envoy-front-proxy": { "component": "envoy-front-proxy" },
    "error-details": { "component": "error-details" },
    "fieldmask": { "component": "fieldmask" },
    "go-package-option": { "component": "go-package-option" },
    "graceful": { "component": "graceful" },
    "grpc-gateway": { "component": "grpc-gateway" },
    "image-proxy": { "component": "image-proxy" },
    "keepalive": { "component": "keepalive" },
    "metadata": { "component": "metadata" },
    "multiple-interceptors": { "component": "multiple-interceptors" },
    "openapi": { "component": "openapi" },
    "protoc": { "component": "protoc" },
    "protoeasy": { "component": "protoeasy" },
    "same-package": { "component": "same-package" },
    "server-reflection": { "component": "server-reflection" },
    "server-streaming": { "component": "server-streaming" },
    "unary": { "component": "unary" },
    "wait-for-ready": { "component": "wait-for-ready" }
  }
}
